# Copy to .env and fill in real values. .env is gitignored.
# See docs/secrets.md for rotation guidance and production hardening.

# === Postgres ===
POSTGRES_USER=archmind
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=archmind

# === Backend connection (must match the Postgres credentials above) ===
ConnectionStrings__Default=Host=postgres;Port=5432;Database=archmind;Username=archmind;Password=change-me-strong-password

# === Anthropic ===
Anthropic__ApiKey=sk-ant-...
# Optional overrides; defaults route Haiku 4.5 for extraction + Sonnet 4.6 for correlation.
# Anthropic__ExtractionModel=claude-haiku-4-5-20251001
# Anthropic__CorrelationModel=claude-sonnet-4-6

# === GitHub App (read-only access to private repos; leave blank for public-only) ===
GitHub__AppId=
GitHub__InstallationId=
GitHub__PrivateKeyPath=/etc/archmind/github-app.pem

# === Admin UI ===
NEXT_PUBLIC_API_URL=http://localhost:5000

# === Cookie / CORS ===
Auth__RequireHttps=false                                # set true in production behind HTTPS
Cors__AllowedOrigins__0=http://localhost:3000           # add admin UI origin(s); index per allowed origin

# === Logging ===
Logging__FilePath=/var/log/archmind                     # mounted via ./logs:/var/log/archmind

# === Polling ===
Polling__IntervalMinutes=15

# === Admin seed (dev only — change immediately after first login) ===
AdminSeed__Email=admin@archmind.local
AdminSeed__Password=change-me-on-first-login

# === ASP.NET environment ===
# Set to Production in production deployments. Migrations only auto-apply in
# non-Production environments — see README "Updating" for prod migration steps.
ASPNETCORE_ENVIRONMENT=Development

# === Legacy aliases (kept for backwards compatibility with earlier sprints) ===
# ANTHROPIC_API_KEY=sk-ant-...
# JWT_SECRET=change-me-in-prod
